{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Zephyr: Set Active Project",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/zephyr-project.sh",
        "set"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Zephyr: Build Active Project",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/zephyr-project.sh",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Zephyr: Flash Active Project",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/zephyr-project.sh",
        "flash",
        "/dev/ttyACM0"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Zephyr: Monitor (miniterm)",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "serial.tools.miniterm",
        "--raw",
        "/dev/ttyACM0",
        "115200"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "isBackground": true
    },
    {
      "label": "Debug: OpenOCD (Active Project)",
      "type": "shell",
      "command": "openocd",
      "args": [
        "-f",
        "/workspace/boards/esp32s3-zephyr.cfg",
        "-c",
        "init; reset halt; esp appimage_offset 0x0"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "custom",
          "pattern": {
            "regexp": "."
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "Listening on port 3333 for gdb connections"
          }
        }
      ]
    },
    {
      "label": "Debug: OpenOCD (Active Project, Dedicated Panel)",
      "type": "shell",
      "command": "openocd",
      "args": [
        "-f",
        "/workspace/boards/esp32s3-zephyr.cfg",
        "-c",
        "init; reset halt; esp appimage_offset 0x0"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "custom",
          "pattern": {
            "regexp": "."
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "Listening on port 3333 for gdb connections"
          }
        }
      ]
    },
    {
      "label": "Debug: Restart OpenOCD (Active Project)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Debug: Stop OpenOCD",
        "Debug: OpenOCD (Active Project, Dedicated Panel)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Debug: Flash then OpenOCD (Active Project)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Zephyr: Flash Active Project",
        "Debug: Stop OpenOCD",
        "Debug: OpenOCD (Active Project, Dedicated Panel)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Debug: Stop OpenOCD",
      "type": "shell",
      "command": "pkill -f 'openocd' || true",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Debug: Prepare ESP32-S3 Session",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Zephyr: Build Active Project",
        "Debug: OpenOCD (Active Project)"
      ],
      "problemMatcher": []
    }
  ]
}