{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Zephyr: Set Active Project",
      "type": "shell",
      "command": "bash",
      "args": [
        "/workspace/scripts/zephyr-project.sh",
        "set",
        "${input:zephyrAppDir}"
      ],
      "options": {
        "cwd": "/workspace"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Zephyr: Build Active Project",
      "type": "shell",
      "command": "bash",
      "args": [
        "/workspace/scripts/zephyr-project.sh",
        "build"
      ],
      "options": {
        "cwd": "/workspace"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Zephyr: Flash Active Project",
      "type": "shell",
      "command": "bash",
      "args": [
        "/workspace/scripts/zephyr-project.sh",
        "flash",
        "/dev/ttyACM0"
      ],
      "options": {
        "cwd": "/workspace"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Zephyr: Monitor (miniterm)",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "serial.tools.miniterm",
        "--raw",
        "/dev/ttyACM0",
        "115200"
      ],
      "options": {
        "cwd": "/workspace/apps/01_blink"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "isBackground": true
    },
    {
      "label": "Debug: OpenOCD (ESP32-S3 Built-in JTAG)",
      "type": "shell",
      "command": "openocd",
      "args": [
        "-f", "/workspace/boards/esp32s3-zephyr.cfg",
        "-c", "init; reset halt; esp appimage_offset 0x0"
      ],
      "options": {
        "cwd": "/workspace"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "custom",
          "pattern": {
            "regexp": "."
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "Listening on port 3333 for gdb connections"
          }
        }
      ]
    },
    {
      "label": "Debug: OpenOCD (esp32s3-builtin)",
      "type": "shell",
      "command": "openocd",
      "args": [
        "-f", "/workspace/boards/esp32s3-zephyr.cfg",
        "-c", "init; reset halt; esp appimage_offset 0x0"
      ],
      "options": {
        "cwd": "/workspace"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "custom",
          "pattern": {
            "regexp": "."
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "Listening on port 3333 for gdb connections"
          }
        }
      ]
    },
    {
      "label": "Debug: Restart OpenOCD (esp32s3-builtin)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Debug: Stop OpenOCD",
        "Debug: OpenOCD (esp32s3-builtin)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Debug: Flash then OpenOCD (esp32s3-builtin)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Zephyr: Flash Active Project",
        "Debug: Stop OpenOCD",
        "Debug: OpenOCD (esp32s3-builtin)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Debug: Stop OpenOCD",
      "type": "shell",
      "command": "pkill -f 'openocd' || true",
      "options": {
        "cwd": "/workspace"
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Debug: Prepare ESP32-S3 Session",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Zephyr: Build Active Project",
        "Debug: OpenOCD (ESP32-S3 Built-in JTAG)"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "zephyrAppDir",
      "type": "pickString",
      "description": "Select the Zephyr app to make active",
      "default": "/workspace/apps/01_blink",
      "options": [
        "/workspace/apps/01_blink",
        "/workspace/apps/02_demo_cmake",
        "/workspace/apps/02_solution_hello_blink",
        "/workspace/apps/03_demo_kconfig",
        "/workspace/apps/03_solution_kconfig_float",
        "/workspace/apps/04_demo_button",
        "/workspace/apps/04_solution_button_led",
        "/workspace/apps/05_demo_adc",
        "/workspace/apps/05_solution_pwm_knob",
        "/workspace/apps/06_demo_device_driver",
        "/workspace/apps/06_solution_i2c_driver",
        "/workspace/apps/07_solution_usb_print",
        "/workspace/apps/08_demo_multithreading",
        "/workspace/apps/08_demo_mutex",
        "/workspace/apps/08_solution_sensor_queue",
        "/workspace/apps/09_demo_counter_interrupt",
        "/workspace/apps/09_demo_gpio_interrupt",
        "/workspace/apps/09_demo_timer",
        "/workspace/apps/09_solution_workqueue",
        "/workspace/apps/10_demo_display",
        "/workspace/apps/10_solution_animation",
        "/workspace/apps/11_demo_wifi",
        "/workspace/apps/11_solution_http",
        "/workspace/apps/12_demo_custom_board",
        "/workspace/apps/12_solution_custom_board",
        "/workspace/apps/Zephyr_ESP32S3-N16R8",
        "/workspace/apps/hello_world_blackpill",
        "/workspace/projects/hello_eink"
      ]
    }
  ]
}