{
    "configurations": [
        {
            "name": "Zephyr Dev Container",
            "includePath": [
                "${workspaceFolder}/**",
                "/opt/toolchains/zephyr/**"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/**",
                    "/opt/toolchains/zephyr/**"
                ],
                "limitSymbolsToIncludedHeaders": true
            },
            "compileCommands": "/workspace/compile_commands.json",
            "compilerPath": "/workspace/.vscode/.zephyr-tools/xtensa-espressif_esp32s3_zephyr-elf-gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ],
    "version": 4
}